# Anthropic API — obligatoire
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Modèle utilisé (ne pas modifier en v1)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max tokens par agent (ajuster si réponses trop longues/courtes)
MAX_TOKENS_RESEARCHER=800
MAX_TOKENS_REASONER=1000
MAX_TOKENS_SYNTHESIZER=1500

# CORS — séparer par virgule. Ajouter l'URL Vercel après déploiement.
DEMO_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://fuegobrain-demo.vercel.app

# Timeout par appel agent (secondes)
AGENT_TIMEOUT_SECONDS=30

# Délai entre agents en cas de rate limit 429 (secondes)
RATE_LIMIT_RETRY_DELAY=1.0
