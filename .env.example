# ── Clés API par provider ────────────────────────────────────────────
# Renseigner UNIQUEMENT la/les clé(s) correspondant aux providers
# réellement utilisés ci-dessous. Au minimum : la clé du provider par défaut.

# Gemini — PROVIDER PAR DÉFAUT, tier gratuit confirmé (Flash/Flash-Lite,
# pas de carte bancaire requise). Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral — tier gratuit "Experiment" confirmé, sans CB.
# Obtenir une clé : https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Anthropic — payant dès la première requête (pas de tier gratuit).
# Obtenir une clé : https://console.anthropic.com
ANTHROPIC_API_KEY=

# Grok / xAI — payant dès la première requête. Aucun tier gratuit fiable
# confirmé sur la documentation officielle au 2026-06-30 (des sources
# tierces mentionnent d'anciens programmes de crédits, non confirmés
# par x.ai/api). Obtenir une clé : https://console.x.ai
GROK_API_KEY=

# ── Provider + modèle par agent ──────────────────────────────────────
# Chaque agent peut utiliser un provider et un modèle différents.
# Valeurs valides pour *_PROVIDER : anthropic | mistral | gemini | grok
RESEARCHER_PROVIDER=gemini
RESEARCHER_MODEL=gemini-2.5-flash

REASONER_PROVIDER=gemini
REASONER_MODEL=gemini-2.5-flash

SYNTHESIZER_PROVIDER=gemini
SYNTHESIZER_MODEL=gemini-2.5-flash

# Exemple de configuration mixte (commenté, à titre d'illustration) :
# RESEARCHER_PROVIDER=mistral
# RESEARCHER_MODEL=mistral-small-latest
# SYNTHESIZER_PROVIDER=anthropic
# SYNTHESIZER_MODEL=claude-sonnet-4-6

# ── Max tokens par agent (ajuster si réponses trop longues/courtes) ──
MAX_TOKENS_RESEARCHER=800
MAX_TOKENS_REASONER=1000
MAX_TOKENS_SYNTHESIZER=1500

# ── CORS — séparer par virgule. Ajouter l'URL Vercel après déploiement.
DEMO_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://fuegobrain-demo.vercel.app

# ── Timeout par appel agent (secondes)
AGENT_TIMEOUT_SECONDS=30

# ── Délai entre agents en cas de rate limit 429 (secondes)
RATE_LIMIT_RETRY_DELAY=1.0
